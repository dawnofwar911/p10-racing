# 1. Quality Gates (Lint, Type Check, Test)
echo "🔍 Running Linting..."
npm run lint

echo "⌨️ Running Type Checks..."
npm run type-check

echo "🧪 Running Tests..."
npm test

# 2. Sync package-lock.json if package.json is staged
if [ "$(git diff --cached --name-only package.json)" = "package.json" ]; then
  echo "📦 package.json change detected. Synchronizing package-lock.json..."
  npm install --package-lock-only
  git add package-lock.json
fi
