{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": ["./*"]
    },
    "types": ["vitest/globals"]
  },
  "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", ".next/types/**/*.ts"],
  "exclude": [
    "node_modules",
    "playwright.config.ts",
    "tests/e2e/**/*",
    "lib/supabase/edge_function_check.ts",
    "lib/supabase/edge_function_sender.ts",
    "lib/supabase/sync_github_issues.ts",
    "lib/supabase/f1_live_proxy.ts",
    "lib/supabase/f1_signalr_relay.ts"
  ]
}
